    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.5.8",
    "run-func": "^3.0.0",
    "storybook": "^10.2.16",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-multiple-assets": "^2.2.6",
