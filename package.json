{
  "name": "vite-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web:build": "pnpm --filter @packages/web build",
    "web:serve": "pnpm --filter @packages/web start",
    "doc:build": "pnpm --filter @packages/doc bundle",
    "doc:serve": "pnpm --filter @packages/doc dev",
    "stanza:serve": "pnpm --filter @packages/stanza stanza:server",
    "stanza:build": "pnpm --filter @packages/stanza stanza:build",
    "storybook:serve": "pnpm --filter @packages/storybook storybook",
    "lint": "oxlint -c oxlint.config.ts . --quiet",
    "lint:debug": "oxlint -c oxlint.config.ts .",
    "lint:fix": "oxlint -c oxlint.config.ts . --fix --quiet",
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "fmt": "pnpm run format",
    "fmt:check": "pnpm run format:check",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "type-check": "oxlint -c oxlint.config.ts . --type-aware --type-check --quiet",
    "type-check:tsc": "pnpm run type-check:tsc:web && pnpm run type-check:tsc:stanza && pnpm run type-check:tsc:api && pnpm run type-check:tsc:core && pnpm run type-check:tsc:storybook",
    "type-check:tsc:web": "tsc -p @packages/web/tsconfig.json --noEmit --pretty",
    "type-check:tsc:stanza": "tsc -p @packages/stanza/tsconfig.json --noEmit --pretty",
    "type-check:tsc:api": "tsc -p @packages/api/tsconfig.json --noEmit --pretty",
    "type-check:tsc:core": "tsc -p @packages/core/tsconfig.json --noEmit --pretty",
    "type-check:tsc:storybook": "tsc -p @packages/storybook/tsconfig.json --noEmit --pretty",
    "check-all": "pnpm run format && pnpm run lint && pnpm run type-check && pnpm run test"
  },
  "dependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "copy-anything": "^4.0.5",
    "is-what": "^5.5.0",
    "jotai": "^2.18.0",
    "nanoid": "^5.1.2",
    "pluralize": "^8.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@emotion/babel-plugin": "^11.11.0",
    "@emotion/babel-preset-css-prop": "^11.11.0",
    "@react-types/shared": "^3.33.1",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-links": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/react": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.99.3",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "consola": "^3.4.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.5.8",
    "run-func": "^3.0.0",
    "storybook": "^10.2.16",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "esbuild": "0.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "togostanza"
    ]
  }
}
