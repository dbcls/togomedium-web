{
  "extends": "../../tsconfig.json",
  "include": ["src", ".storybook/preview.tsx"],
  "compilerOptions": {
    "paths": {
      "%stanza/*": ["../stanza/*"],
      "%api/*": ["../api/src/*"],
      "%core/*": ["../core/src/*"],
      "%storybook/*": ["../storybook/src/*"],
      "%web/*": ["../web/src/*"]
    }
  },
  "exclude": ["node_modules", "**/*.spec.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
